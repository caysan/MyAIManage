{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Start Frontend",
      "type": "shell",
      "command": "npx ng serve",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "angular",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "Compiled successfully|compiled successfully"
        }
      }
    },
    {
      "label": "🛑 Frontend'i Durdur",
      "type": "shell",
      "command": "powershell -NoProfile -Command \"Stop-Process -Name node -Force -ErrorAction SilentlyContinue; exit 0\"",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
